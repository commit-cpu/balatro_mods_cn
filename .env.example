APP_ENV=development

QDRANT_API_KEY=replace_me
QDRANT_READ_ONLY_API_KEY=replace_me

# Optional OpenAI-compatible embedding API key. Only required when
# config/app.yml sets embedding.provider=openai-compatible.
EMBEDDING_API_KEY=replace_me

LLM_API_KEY=replace_me
LLM_BASE_URL=https://api.openai.com/v1
LLM_TRANSLATION_MODEL=gpt-4.1-mini
LLM_CONCURRENCY=1
GITHUB_TOKEN=replace_me

# Optional git clone/fetch proxy overrides.
GIT_HTTP_PROXY=http://127.0.0.1:7890
GIT_HTTPS_PROXY=http://127.0.0.1:7890
GIT_NO_PROXY=127.0.0.1,localhost

# Production admin protection. Leave ADMIN_SECRET_KEY empty for local open mode.
ADMIN_PATH_SUFFIX=cnops-balatro-aadmin
ADMIN_SECRET_KEY=
